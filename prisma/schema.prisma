generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String?
  userId    String
  pinned    Boolean  @default(false) 
  color     String   @default("#ffffff")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}